{
  "name": "claude-usage-widget",
  "version": "1.0.0",
  "description": "Windows 11 system-tray widget that tracks Claude Max usage from local Claude Code logs.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "probe": "node src/live-usage.js",
    "icon": "node build/gen-icon.js",
    "pack": "electron-packager . \"Claude Usage\" --overwrite --platform=win32 --arch=ia32 --out=dist --icon=build/icon.ico --ignore=\"^/dist\" --ignore=\"^/\\.git\"",
    "dist": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.claudeusage.widget",
    "productName": "Claude Usage",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "ClaudeUsage-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
